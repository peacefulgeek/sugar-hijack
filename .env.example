# ─── Site ───────────────────────────────────────────────────────────────────
SITE_URL=https://sugarhijack.com

# ─── Writing Engine (DeepSeek via OpenAI-compatible client) ─────────────────
OPENAI_API_KEY=your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# ─── Cron + Auto-Publishing ──────────────────────────────────────────────────
# Set to the date of first deploy (YYYY-MM-DD) — controls Phase 1 vs Phase 2 article cadence
SITE_LAUNCH_DATE=2025-05-06

AUTO_GEN_ENABLED=true

# ─── Affiliate ───────────────────────────────────────────────────────────────
AMAZON_TAG=spankyspinola-20

# ─── Bunny CDN ───────────────────────────────────────────────────────────────
BUNNY_API_KEY=bc90ca4d-ca9a-4449-91fa87d55cd9-c7b3-4a40
BUNNY_STORAGE_ZONE=sugar-hijack
BUNNY_STORAGE_ENDPOINT=https://ny.storage.bunnycdn.com
BUNNY_CDN_URL=https://sugar-hijack.b-cdn.net

# ─── Database (PostgreSQL — optional, falls back to JSON file store) ─────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
